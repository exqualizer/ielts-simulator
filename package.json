{
  "name": "ielts-simulator-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "concurrently -n server,client -c blue,magenta \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build:client": "npm run build --workspace client",
    "build:pages": "npm run build:pages --workspace client",
    "lint": "npm run lint --workspace client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

