CORS_ORIGIN=http://localhost:5173,https://exqualizer.github.io
# Optional: also allow https://<owner>.github.io (merged with CORS_ORIGIN). Handy on Cloud Run.
# CORS_GITHUB_OWNER=exqualizer

# Logging: GCP transport when NODE_ENV is staging|production OR on Cloud Run (K_SERVICE), AND
# (Cloud Run / CLOUD_RUN_JOB, or GOOGLE_APPLICATION_CREDENTIALS, or ENABLE_GCP_LOGGING=true with ADC).
# Otherwise console only.
# LOG_LEVEL=info
# GCP_LOG_NAME=ielts-simulator-api
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# ENABLE_GCP_LOGGING=true
# DISABLE_GCP_LOGGING=true
